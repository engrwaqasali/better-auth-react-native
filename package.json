{
  "name": "better-auth-react-native",
  "version": "1.0.0",
  "description": "Better Auth integration for bare React Native (React Native CLI) applications.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/engrwaqasali/better-auth-react-native",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/engrwaqasali/better-auth-react-native.git"
  },
  "keywords": [
    "auth",
    "react-native",
    "typescript",
    "better-auth"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./plugins": {
      "dev-source": "./src/plugins/index.ts",
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ],
      "plugins": [
        "./dist/plugins/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.18",
    "better-call": "^1.3.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@better-auth/core": "^1.2.7",
    "@better-fetch/fetch": "^1.1.18",
    "@react-native-community/netinfo": "^11.4.1",
    "better-auth": "^1.2.7",
    "react-native": "^0.76.0",
    "react-native-inappbrowser-reborn": "^3.7.0",
    "@arethetypeswrong/cli": "^0.17.0",
    "publint": "^0.3.0",
    "tsdown": "^0.12.6",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@better-auth/core": ">=1.0.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "better-auth": ">=1.0.0",
    "react-native": ">=0.73.0",
    "react-native-inappbrowser-reborn": ">=3.6.0"
  },
  "peerDependenciesMeta": {
    "@react-native-community/netinfo": {
      "optional": true
    },
    "react-native-inappbrowser-reborn": {
      "optional": true
    }
  }
}
